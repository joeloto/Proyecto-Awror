<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutPerfil"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo2"
    android:padding="24dp">

    <EditText
        android:id="@+id/etNombrePerfil"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Nombre"
        android:background="@drawable/edittext_fondo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/etApellidoPerfil"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <EditText
        android:id="@+id/etApellidoPerfil"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Apellido"
        android:background="@drawable/edittext_fondo"
        app:layout_constraintTop_toBottomOf="@id/etNombrePerfil"
        app:layout_constraintBottom_toTopOf="@id/etUsuarioPerfil"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/etUsuarioPerfil"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Nombre de usuario"
        android:background="@drawable/edittext_fondo"
        app:layout_constraintTop_toBottomOf="@id/etApellidoPerfil"
        app:layout_constraintBottom_toTopOf="@id/etEmailPerfil"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/etEmailPerfil"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Email"
        android:background="@drawable/edittext_fondo"
        android:inputType="textEmailAddress"
        app:layout_constraintTop_toBottomOf="@id/etUsuarioPerfil"
        app:layout_constraintBottom_toTopOf="@id/etPasswordPerfil"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/etPasswordPerfil"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Contraseña"
        android:background="@drawable/edittext_fondo"
        android:inputType="textPassword"
        app:layout_constraintTop_toBottomOf="@id/etEmailPerfil"
        app:layout_constraintBottom_toTopOf="@id/layoutBotones"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/layoutBotones"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/btnCerrarSesion"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.489"
        app:layout_constraintStart_toStartOf="parent">

        <Button
            android:id="@+id/btnActualizarPerfil"
            android:layout_width="150dp"
            android:layout_height="120dp"
            android:background="@drawable/hueso"
            android:text="Actualizar" />

        <Button
            android:id="@+id/btnEliminarPerfil"
            android:layout_width="150dp"
            android:layout_height="120dp"
            android:layout_marginStart="16dp"
            android:background="@drawable/hueso"
            android:backgroundTint="@android:color/holo_red_dark"
            android:text="Eliminar"
            android:textColor="@android:color/white" />
    </LinearLayout>

    <Button
        android:id="@+id/btnCerrarSesion"
        android:layout_width="180dp"
        android:layout_height="120dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/hueso"
        android:backgroundTint="@android:color/holo_blue_dark"
        android:text="Cerrar sesión"
        android:textColor="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
